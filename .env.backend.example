# -----------------------------------------------------------------------------
# BACKEND ENVIRONMENT VARIABLES (HOME SERVER DEPLOYMENT)
# Copy file này thành `.env` ở thư mục gốc của Home Server trước khi build.
# -----------------------------------------------------------------------------

# Cổng chạy API Server trên Home Server (Expose ra ngoài Docker)
PORT=3000

# URL của Frontend được host trên Vercel (dùng cho CORS)
# Nếu bạn chạy nhiều domain, hãy phân tách bằng dấu phẩy (không có khoảng trắng dư thừa)
# Ví dụ: CLIENT_URL=https://battleship-game-client.vercel.app,https://www.battleship-game.com
CLIENT_URL=https://YOUR_VERCEL_APP_URL.vercel.app

# Cấu hình Database (PostgreSQL) chạy trong Docker
DB_PORT=5432
DB_NAME=battleship
DB_USER=postgres
DB_PASSWORD=YOUR_STRONG_DB_PASSWORD
DB_SYNCHRONIZE=false
DB_LOGGING=false

# Cấu hình Redis Cache chạy trong Docker
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=YOUR_STRONG_REDIS_PASSWORD
CHAT_HISTORY_LIMIT=80
CHAT_HISTORY_TTL_SECONDS=43200

# Cấu hình bảo mật JWT (Bắt buộc thay đổi ở production!)
JWT_SECRET=YOUR_SUPER_SECRET_JWT_KEY
JWT_REFRESH_SECRET=YOUR_SUPER_SECRET_JWT_REFRESH_KEY
ACCESS_TOKEN_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=30d
REFRESH_TOKEN_ABSOLUTE_TTL_DAYS=180

# Cấu hình Cookie cho Refresh Token
# LƯU Ý QUAN TRỌNG KHI CHẠY KHÁC DOMAIN (Vercel + Home Server):
# 1. COOKIE_SECURE bắt buộc phải là `true` (Trình duyệt chỉ cho phép truyền qua HTTPS).
# 2. COOKIE_SAME_SITE bắt buộc phải là `none` (Cho phép nhận Cookie từ domain khác).
COOKIE_SECURE=true
COOKIE_SAME_SITE=none
COOKIE_PATH=/
COOKIE_DOMAIN=
REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_TOKEN_COOKIE_MAX_AGE_MS=2592000000

# Cấu hình Generative AI (ShopAIKey) nếu có
SHOPAIKEY_API_KEY=your-api-key
SHOPAIKEY_GENAI_BASE_URL=https://api.shopaikey.com
SHOPAIKEY_GENAI_MODEL=gemini-2.5-flash

# Cấu hình Cloudinary để upload hình ảnh
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
