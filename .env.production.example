# ==============================================================================
# BATTLESHIP GAME - PRODUCTION ENVIRONMENT CONFIGURATION EXAMPLE (.env.production)
# ==============================================================================
# Tệp này chứa các biến môi trường cần thiết để chạy Backend trên Home Server.
# Khi deploy qua GitHub Actions, workflow sẽ tự động tạo file .env.production từ các
# GitHub Secrets và Variables được cấu hình bên dưới.
# ==============================================================================

# --- Server & Client Configuration ---
SERVER_IMAGE=ghcr.io/OWNER/p_btship-server:latest
PORT=3001
CLIENT_PORT=8080
CLIENT_URL=http://YOUR_SERVER_IP_OR_DOMAIN

# --- Database (Postgres) ---
DB_PORT=5432
DB_NAME=battleship
DB_USER=postgres
DB_PASSWORD=change-me-strong-password
DB_SYNCHRONIZE=true
DB_LOGGING=false

# --- Admin Account Seeding ---
ADMIN_USERNAME=username
ADMIN_EMAIL=admail@example.com
ADMIN_PASSWORD=change-me-strong-password

# --- Authentication & JWT ---
JWT_SECRET=change-me-secret-key
JWT_REFRESH_SECRET=change-me-refresh-secret-key
ACCESS_TOKEN_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=30d
REFRESH_TOKEN_ABSOLUTE_TTL_DAYS=180
REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_TOKEN_COOKIE_MAX_AGE_MS=2592000000

# --- Cookie Security ---
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
COOKIE_PATH=/
COOKIE_DOMAIN=

# --- Redis Cache & Session ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=change-me-strong-redis-pass
CHAT_HISTORY_LIMIT=80
CHAT_HISTORY_TTL_SECONDS=43200

# --- AI & Cloud Services ---
SHOPAIKEY_API_KEY=
SHOPAIKEY_GENAI_BASE_URL=https://api.shopaikey.com
SHOPAIKEY_GENAI_MODEL=gemini-2.5-flash

CLOUDINARY_CLOUD_NAME=name
CLOUDINARY_API_KEY=key
CLOUDINARY_API_SECRET=secret


# ==============================================================================
# HƯỚNG DẪN CẤU HÌNH GITHUB ACTIONS CI/CD (.github/workflows/deploy.yml)
# ==============================================================================
# Vào GitHub Repository -> Settings -> Secrets and variables -> Actions
# 
# 1. GITHUB SECRETS (Bí mật cần bảo vệ):
#    --- Tailscale VPN Deployment ---
#    TS_OAUTH_CLIENT_ID : Client ID từ Tailscale OAuth (Scopes: Devices -> Write)
#    TS_OAUTH_SECRET    : Client Secret từ Tailscale OAuth
#    
#    --- Home Server SSH Connection ---
#    SERVER_HOST        : Địa chỉ IP Tailscale của Home Server (VD: 100.x.x.x) hoặc MagicDNS name
#    SERVER_PORT        : Cổng SSH trên Home Server (Mặc định: 22)
#    SERVER_USERNAME    : Tên user đăng nhập máy CasaOS/Home Server (VD: namkhuc)
#    SERVER_DEPLOY_PATH : Đường dẫn thư mục chứa docker-compose.prod.yml trên Home Server
#    SSH_PRIVATE_KEY    : Nội dung khóa riêng tư SSH (~/.ssh/id_rsa hoặc ~/.ssh/id_ed25519)
#    
#    --- Application Secrets ---
#    CLIENT_URL, DB_NAME, DB_USER, DB_PASSWORD, JWT_SECRET, JWT_REFRESH_SECRET
#    REDIS_PASSWORD, ADMIN_USERNAME, ADMIN_EMAIL, ADMIN_PASSWORD
#    SHOPAIKEY_API_KEY, CLOUDINARY_API_KEY, CLOUDINARY_CLOUD_NAME, CLOUDINARY_API_SECRET
#
# 2. GITHUB VARIABLES (Các biến cấu hình chung):
#    PORT, DB_PORT, REDIS_PORT, REDIS_DB, DB_SYNCHRONIZE, DB_LOGGING
#    ACCESS_TOKEN_EXPIRES_IN, REFRESH_TOKEN_EXPIRES_IN, REFRESH_TOKEN_ABSOLUTE_TTL_DAYS
#    REFRESH_TOKEN_COOKIE_NAME, REFRESH_TOKEN_COOKIE_MAX_AGE_MS
#    COOKIE_SECURE, COOKIE_SAME_SITE, COOKIE_PATH, COOKIE_DOMAIN
#    CHAT_HISTORY_LIMIT, CHAT_HISTORY_TTL_SECONDS
#    SHOPAIKEY_GENAI_BASE_URL, SHOPAIKEY_GENAI_MODEL
# ==============================================================================

